# ── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://polish:polish_secret@localhost:5432/polish_db"

# ── Redis ────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT (generate with: openssl rand -hex 32) ────────
JWT_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET=""
JWT_REFRESH_EXPIRES_IN=""

# ── Cloudflare R2 / S3 ───────────────────────────────
S3_BUCKET="polish-documents"
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""        # e.g. https://<account_id>.r2.cloudflarestorage.com

# ── Google AI (Gemini 2.5 Flash) ─────────────────────
GOOGLE_AI_API_KEY=""

# ── Frontend ──────────────────────────────────────────
CLIENT_URL="http://localhost:3000" (You can also replace this with you railway URL)
NEXT_PUBLIC_API_URL="http://localhost:5000" (You can also replace this with you railway URL)
