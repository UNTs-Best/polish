{
  "name": "server",
  "version": "1.0.0",
  "description": "Polish API server",
  "license": "ISC",
  "type": "commonjs",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "node --test dist/test/**/*.test.js",
    "test:watch": "node --test --watch dist/test/**/*.test.js",
